# Game subdomain prefix, e.g. snake
SUBDOMAIN=
# Apex or parent domain from your DNS setup
DOMAIN_NAME=
# ID of the existing Route 53 hosted zone
HOSTED_ZONE_ID=
# ARN of the existing wildcard ACM certificate
CERTIFICATE_ARN=
# AWS account ID
AWS_ACCOUNT_ID=
# AWS region — must be us-east-1 for ACM + CloudFront
AWS_REGION=
# Optional: named AWS credentials profile
AWS_PROFILE=
